{
  // VS Code launch configurations for my-music
  //
  // HOW TO SET ENVIRONMENT VARIABLES
  // ---------------------------------
  // Two options — pick one:
  //
  // Option A — Hardcode directly in this file (DO NOT commit with real tokens):
  //   Replace the placeholder strings below with your actual token values.
  //   Add launch.json to .gitignore if you go this route.
  //
  // Option B — Read from your OS environment / a .env file (recommended):
  //   Use "${env:VAR_NAME}" syntax (already shown below for the pytest config).
  //   Install the "DotENV" VS Code extension (mikestead.dotenv) and create a
  //   .env file in the project root with:
  //       DISCOGS_TOKEN=your_token_here
  //       GENIUS_TOKEN=your_token_here
  //       ANTHROPIC_API_KEY=sk-ant-...
  //   VS Code will load these automatically via the extension.
  //
  // NOTE: .env is already in .gitignore — safe to store real tokens there.
  "version": "0.2.0",
  "configurations": [

    {
      "name": "Python Debugger: Biffy Clyro",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "args": [
        "--genius-token",
        "09iag5csxuk9LqudHubuDZJSuXBbfKWYatyZPrclAMI6wom-c3WSimcutTYCnqAh",
        "--artist",
        "Biffy Clyro",
        "--title", 
        "Break A Butterfly On A Wheel"
      ]
    },
    {
      // Run the full test suite. Uses ${env:VAR} so tokens come from your
      // OS environment or a .env file loaded by the DotENV extension.
      "name": "pytest (all tests)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/",
        "-v"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "DISCOGS_TOKEN": "${env:DISCOGS_TOKEN}",
        "GENIUS_TOKEN": "${env:GENIUS_TOKEN}",
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}"
      },
      "justMyCode": false
    },
    {
      // Run a single test file — change the path in args as needed.
      "name": "pytest (current file)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}",
        "-v"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "DISCOGS_TOKEN": "${env:DISCOGS_TOKEN}",
        "GENIUS_TOKEN": "${env:GENIUS_TOKEN}",
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}"
      },
      "justMyCode": false
    },
    {
      // Run Flask locally (not in Docker). Tokens are hardcoded here for
      // convenience — replace the placeholder values and DO NOT commit.
      "name": "Flask (local)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "cwd": "${workspaceFolder}",
      "env": {
        "DISCOGS_TOKEN": "YOUR_DISCOGS_TOKEN_HERE",
        "GENIUS_TOKEN": "YOUR_GENIUS_TOKEN_HERE",
        "ANTHROPIC_API_KEY": "sk-ant-...",
        "OLLAMA_HOST": "http://localhost:11434",
        "OLLAMA_MODEL": "llama3",
        "DB_PATH": "${workspaceFolder}/data/music.db"
      }
    }
  ]
}